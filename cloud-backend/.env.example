# Server Config
PORT=5001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# PostgreSQL (required — cloud backend uses PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nirikshan_cloud

JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=1d

# Cloudinary (required for media upload — snapshots and video clips)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Firebase (optional — for push notifications)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Default organization created on first seed
DEFAULT_ORG_NAME=Nirikshan

# Super Admin credentials for seeding
SUPER_ADMIN_EMAIL=admin@nirikshan.cloud
SUPER_ADMIN_PASSWORD=Admin@123

# Default edge device (optional — created during seed, must match backend/.env)
# DEFAULT_EDGE_DEVICE_ID=<your-edge-device-uuid>
# DEFAULT_EDGE_API_KEY=<your-edge-device-api-key>
