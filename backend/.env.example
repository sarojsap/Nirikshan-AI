# Server Config
PORT=5000
NODE_ENV=development

# Edge deployment uses SQLite (zero-config, no PostgreSQL needed)
# Set USE_SQLITE=false to use PostgreSQL
USE_SQLITE=true

# PostgreSQL — only used when USE_SQLITE=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nirikshan_ai

# SQLite — used when USE_SQLITE=true
LOCAL_DB_PATH=./data/nirikshan-edge.db

JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=1d

# Email SMTP (optional — needed for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com

RESET_TOKEN_EXPIRES_IN=15m
CLIENT_URL=http://localhost:5173

# Super Admin credentials created on first run
SUPER_ADMIN_EMAIL=admin@nirikshan.local
SUPER_ADMIN_PASSWORD=password123
SUPER_ADMIN_NAME=Super Admin

# Firebase (optional — for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Edge Sync to Cloud ──
# Set CLOUD_API_URL to enable cloud sync. Leave empty for local-only mode.
CLOUD_API_URL=http://localhost:5001/api
# Edge device credentials — register via cloud API or pre-configure
EDGE_ID=your-edge-device-uuid
EDGE_API_KEY=your-edge-device-api-key
# Local media storage
MEDIA_DIR=./media
